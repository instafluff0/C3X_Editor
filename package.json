{
  "name": "civ3-c3x-modern-config-manager",
  "productName": "Civ 3 C3X Modern Editor",
  "version": "27.12.1",
  "description": "Modern config manager for C3X",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node scripts/run-tests.js fast",
    "test:fast": "node scripts/run-tests.js fast",
    "test:map-critical": "node scripts/run-tests.js map-critical",
    "test:biq": "node scripts/run-tests.js biq",
    "test:full": "node scripts/run-tests.js full",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "electron-icon-maker": "^0.0.5"
  },
  "build": {
    "appId": "com.instafluff.c3xconfigmanager",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "createStartMenuShortcut": true,
      "shortcutName": "Civ 3 C3X Modern Editor"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    }
  },
  "dependencies": {
    "iconv-lite": "^0.6.3"
  }
}
